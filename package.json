    "eslint": "^10.2.0",
    "express": "^4.19.2",
    "fs-extra": "^10.0.1",
    "globals": "^17.4.0",
    "jsdoc": "^4.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  }
